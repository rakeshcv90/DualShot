		<key>NSAllowsArbitraryLoads</key>
		<false/>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
	<key>NSCameraUsageDescription</key>
	<string>DualShot uses your camera to record videos and take photos, then generates both portrait and landscape versions of your recording.</string>
	<key>NSDocumentsFolderUsageDescription</key>
	<string>DualShot accesses your Documents folder to let you select files to share and to save received files.</string>
	<key>NSLocalNetworkUsageDescription</key>
	<string>DualShot uses your local network to discover and connect to nearby devices for direct peer-to-peer sharing.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>DualShot uses location services to help discover nearby devices for fast file sharing.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>DualShot requires microphone access to record high-quality audio for your videos.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>DualShot saves your captured videos directly to your photo library.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>DualShot accesses your photo library to save and share your recordings.</string>
  <key>NSAppleMusicUsageDescription</key>
  <string>This app may access your media library to allow users to select audio or media content.</string>
  <key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
  <string>This app uses your location to provide location-based features when needed.</string>
  <key>NSLocationWhenInUseUsageDescription</key>
  <string>This app uses your location to provide location-based features.</string>
